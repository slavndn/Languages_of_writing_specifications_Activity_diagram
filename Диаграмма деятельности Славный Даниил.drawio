<mxfile host="app.diagrams.net">
  <diagram name="Страница-1" id="mq1A0v5YmxKtapPpGGYM">
    <mxGraphModel dx="1178" dy="738" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Подготовка к защите ВКР\n\nskinparam shadowing false\nskinparam defaultFontName Arial\nskinparam activity {\n  BackgroundColor #F8FAFC\n  BorderColor #0F172A\n  FontColor #0F172A\n  ArrowColor #334155\n}\n\nstart\n\npartition \&quot;Студент\&quot; {\n  :Утвердить тему и ТЗ/план ВКР\\n(веб-приложение учета спортивных достижений);\n  :Собрать требования и источники;\n  :Спроектировать решение (архитектура, БД, UX);\n  :Реализовать и настроить веб‑приложение;\n  :Провести тестирование и исправления;\n  :Подготовить текст ВКР\\n(введение, анализ, проектирование, реализация, тесты, заключение);\n}\n\npartition \&quot;Руководитель\&quot; {\n  :Проверка текста/материалов;\n}\n\nwhile (Есть замечания?) is (да)\n  partition \&quot;Студент\&quot; {\n    :Внести правки в текст ВКР;\n  }\n  partition \&quot;Руководитель\&quot; {\n    :Повторная проверка;\n  }\nendwhile (нет)\n\npartition \&quot;Студент\&quot; {\n  fork\n    :Оформить репозиторий/исходный код\\n(README, инструкция запуска, скриншоты);\n  fork again\n    :Подготовить презентацию;\n  fork again\n    :Подготовить доклад/речь\\nи ответы на вопросы;\n  fork again\n    :Подготовить приложения\\n(руководство пользователя, примеры отчетов);\n  end fork\n\n  :Сформировать финальную версию ВКР\\n(оформление по метод.указаниям);\n  :Проверить оригинальность\\n(антиплагиат, при необходимости — доработка);\n}\n\npartition \&quot;Руководитель\&quot; {\n  :Составить отзыв руководителя;\n}\n\npartition \&quot;Кафедра/комиссия\&quot; {\n  :Назначить рецензента (если требуется);\n  :Получить рецензию (если требуется);\n}\n\npartition \&quot;Студент\&quot; {\n  :Собрать пакет на защиту:\\n- текст ВКР\\n- отзыв руководителя\\n- рецензия (если есть)\\n- презентация\\n- доп.материалы/приложения;\n  :Загрузить материалы в систему\\n(ЛМС/портал/почта);\n  :Подготовить печатные экземпляры\\nи подписи (если требуется);\n  :Пробная защита/репетиция (опционально);\n}\n\npartition \&quot;ГЭК\&quot; {\n  :Защита ВКР;\n  :Вопросы комиссии;\n  :Оценивание и объявление результата;\n}\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="3J2Z_3nCoPThskb_tlgH-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1910" width="998" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
